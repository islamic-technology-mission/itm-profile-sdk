<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Islam360 SDK"
            android:textColor="#1A1A2E"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Select a profile to load"
            android:textColor="#6C6C80"
            android:textSize="14sp" />

        <!-- Profile Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnProfile1"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="P1"
                android:textSize="13sp"
                app:backgroundTint="#4F46E5" />

            <Button
                android:id="@+id/btnProfile2"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="P2"
                android:textSize="13sp"
                app:backgroundTint="#4F46E5" />

            <Button
                android:id="@+id/btnProfile3"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="P3"
                android:textSize="13sp"
                app:backgroundTint="#4F46E5" />

            <Button
                android:id="@+id/btnProfile4"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="P4"
                android:textSize="13sp"
                app:backgroundTint="#4F46E5" />

        </LinearLayout>

        <!-- Progress + Status -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:textColor="#6C6C80"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- ── Profile Card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:letterSpacing="0.1"
                    android:text="PROFILE"
                    android:textColor="#4F46E5"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:textColor="#1A1A2E"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:textColor="#6C6C80"
                    android:textSize="13sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="12dp"
                    android:background="#F0F0F0" />

                <include
                    android:id="@+id/rowPhone"
                    layout="@layout/item_profile_row" />

                <include
                    android:id="@+id/rowGender"
                    layout="@layout/item_profile_row" />

                <include
                    android:id="@+id/rowDob"
                    layout="@layout/item_profile_row" />

                <include
                    android:id="@+id/rowLocation"
                    layout="@layout/item_profile_row" />

                <include
                    android:id="@+id/rowNearby"
                    layout="@layout/item_profile_row" />

                <include
                    android:id="@+id/rowJoined"
                    layout="@layout/item_profile_row" />

                <include
                    android:id="@+id/rowCountry"
                    layout="@layout/item_profile_row" />

                <include
                    android:id="@+id/rowCity"
                    layout="@layout/item_profile_row" />


                <include
                    android:id="@+id/rowBlocked"
                    layout="@layout/item_profile_row" />


                <!-- Update Profile Button -->
                <Button
                    android:id="@+id/btnUpdateProfile"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:text="Update Profile Name"
                    android:textSize="13sp"
                    app:backgroundTint="#4F46E5" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Screen Time Card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardScreenTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:letterSpacing="0.1"
                    android:text="SCREEN TIME"
                    android:textColor="#4F46E5"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvScreenTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:textColor="#1A1A2E"
                    android:textSize="13sp" />

                <!-- Add Screen Time Button -->
                <Button
                    android:id="@+id/btnAddScreenTime"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Add 60s Screen Time (Today)"
                    android:textSize="13sp"
                    app:backgroundTint="#059669" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Profile Views Card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardProfileViews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="visible"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:letterSpacing="0.1"
                    android:text="PROFILE VIEWS"
                    android:textColor="#4F46E5"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProfileViews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:textColor="#1A1A2E"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnLoadProfileViews"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Load Profile Views"
                    android:textSize="13sp"
                    app:backgroundTint="#7C3AED" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- ── Nearby Users Card ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardNearbyUsers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="visible"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:letterSpacing="0.1"
                    android:text="NEARBY USERS"
                    android:textColor="#4F46E5"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNearbyUsers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:textColor="#1A1A2E"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnLoadNearbyUsers"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Load Nearby Users"
                    android:textSize="13sp"
                    app:backgroundTint="#0891B2" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>